{
  "name": "kinos",
  "private": true,
  "version": "0.1.0",
  "description": "KinOS \u2014 the private family operating system for the people you love.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @kinos/web dev",
    "build": "pnpm --filter @kinos/web build",
    "start": "pnpm --filter @kinos/web start",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel test",
    "test:engine": "pnpm --filter @kinos/engine test",
    "language:check": "node scripts/check-language.mjs",
    "db:seed": "pnpm --filter @kinos/db seed",
    "db:types": "pnpm --filter @kinos/db gen-types"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "packageExtensions": {
      "next": {
        "dependencies": {
          "@types/react": "^19.0.2",
          "@types/react-dom": "^19.0.2"
        }
      }
    },
    "overrides": {
      "undici@<6.27.0": ">=6.27.0",
      "tar@<7.5.10": ">=7.5.10",
      "postcss@<8.5.10": ">=8.5.10",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13",
      "uuid@<11.1.1": ">=11.1.1",
      "vite@<5.4.21": ">=5.4.21",
      "vite@>=6.0.0 <6.4.3": ">=6.4.3",
      "esbuild@<0.25.0": ">=0.25.0"
    }
  }
}