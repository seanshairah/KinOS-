{
  "expo": {
    "name": "KinOS",
    "slug": "kinos",
    "version": "0.1.0",
    "scheme": "kinos",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#F6F2EC",
    "ios": {
      "bundleIdentifier": "family.kinos.app",
      "supportsTablet": false
    },
    "android": {
      "package": "family.kinos.app",
      "adaptiveIcon": {
        "backgroundColor": "#35335F"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
