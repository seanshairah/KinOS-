# ─── KinOS environment ───────────────────────────────────────────────
# Copy to apps/web/.env.local for development. Everything degrades
# gracefully: without a database the app shows a guided setup screen;
# without provider keys the deterministic composers take over.

# Neon Postgres — pooled connection string (required for the product)
DATABASE_URL=postgres://user:password@ep-xxx-pooler.region.aws.neon.tech/kinos?sslmode=require

# Auth.js — generate with: openssl rand -base64 32   (required for sign-in)
AUTH_SECRET=

# Public URL of this deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — magic-link sign-in emails + notifications.
# Without it, dev prints the magic link to the server console.
RESEND_API_KEY=
NOTIFICATIONS_FROM_EMAIL="KinOS <brief@yourdomain>"

# Vercel Blob — receipts, voice notes, documents (optional; uploads skip without it)
BLOB_READ_WRITE_TOKEN=

# Internal intelligence layer (server-only; never rendered in the product).
# Without it, briefs use the deterministic composer and notes queue for review.
MODEL_PROVIDER_API_KEY=
MODEL_ID=claude-opus-4-8

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=

# Web push (generate with: npx web-push generate-vapid-keys)
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# Scheduled jobs — Vercel Cron sends this as a bearer token
CRON_SECRET=

# Observability (optional)
SENTRY_DSN=
